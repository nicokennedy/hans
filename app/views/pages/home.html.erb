<section class="hero">
  <div class="container">
    <div class="row align-items-center">
      <div class="col-lg-6">
        <h1 class="hero-title">
          Portal mayorista<br>
          HANS Pastelería
        </h1>

        <p class="hero-subtitle">
          Hacé tus pedidos de forma simple, rápida y organizada.
          Elegí productos, fecha de entrega y repetí pedidos anteriores en segundos.
        </p>

        <div class="mt-4">
          <%= link_to "Ingresar al portal",
            new_user_session_path,
            class: "btn btn-hans" %>
        </div>
      </div>

      <div class="col-lg-6 mt-5 mt-lg-0">
        <div class="row g-3">
          <% Product.limit(6).each do |product| %>
            <div class="col-6">
              <div class="product-card">
                <div class="product-title">
                  <%= product.name %>
                </div>

                <div class="text-muted small mb-2">
                  <%= product.category.name %>
                </div>

                <div class="product-price">
                  $<%= number_with_delimiter(product.price_cents / 100) %>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</section>