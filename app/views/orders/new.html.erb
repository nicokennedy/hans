<div class="container py-5">
  <div class="mb-5">
    <h1 class="fw-bold mb-1">
      Confirmar pedido
    </h1>

    <div class="text-muted">
      Revisá la información antes de enviar el pedido
    </div>
  </div>

  <div class="row g-4">
    <div class="col-lg-7">
      <div class="product-card">
        <h4 class="mb-4">
          Productos
        </h4>

        <% total_cents = 0 %>

        <% @cart_items.each do |item| %>
          <% total_cents += item[:subtotal_cents] %>

          <div class="d-flex justify-content-between mb-3 pb-3 border-bottom">
            <div>
              <div class="fw-bold">
                <%= item[:product].name %>
              </div>

              <div class="text-muted small">
                x<%= item[:quantity] %>
              </div>
            </div>

            <div class="fw-bold">
              $<%= number_with_delimiter(item[:subtotal_cents] / 100) %>
            </div>
          </div>
        <% end %>

        <div class="d-flex justify-content-between mt-4">
          <strong>Total</strong>

          <strong class="fs-5">
            $<%= number_with_delimiter(total_cents / 100) %>
          </strong>
        </div>
      </div>
    </div>

    <div class="col-lg-5">
      <div class="product-card">

      <% if @order&.errors&.any? %>
				<div class="alert alert-danger">
					<strong>No pudimos crear el pedido:</strong>

					<ul class="mb-0 mt-2">
						<% @order.errors.each do |error| %>
							<li><%= error.message %></li>
						<% end %>

					</ul>
				</div>
			<% end %>
        <%= form_with model: (@order || Order.new) do |f| %>

          <div class="mb-4">
            <%= f.label :delivery_date,
              "Fecha de entrega",
              class: "form-label fw-bold" %>

            <%= f.text_field :delivery_date,
              value: nil,
              class: "form-control hans-input",
              id: "delivery-date-picker",
              autocomplete: "off",
              placeholder: "Seleccioná una fecha" %>
          </div>

          <div class="mb-4">
            <%= f.label :payment_method_selected,
              "Forma de pago",
              class: "form-label fw-bold" %>

            <%= f.select :payment_method_selected,
              [
                ["Efectivo contra entrega", "cash_on_delivery"],
                ["Cuenta Corriente", "cash_later"],
                ["Transferencia", "bank_transfer"]
              ],
              {},
              class: "form-select hans-input" %>
          </div>

          <div class="mb-4">
            <%= f.label :customer_comment,
              "Comentario",
              class: "form-label fw-bold" %>

            <%= f.text_area :customer_comment,
              rows: 4,
              class: "form-control",
              placeholder: "Ej: entregar temprano, sin caja individual..." %>
          </div>

          <div class="d-grid">
            <%= f.submit "Confirmar pedido",
              class: "btn btn-hans btn-lg" %>
          </div>

        <% end %>
      </div>
    </div>
  </div>
</div>

<script>
function initDeliveryDatePicker() {
  const input = document.querySelector("#delivery-date-picker")

  if (!input) return
  if (typeof flatpickr === "undefined") return

  if (input._flatpickr) {
    input._flatpickr.destroy()
  }

  const disabledDays = <%= DeliverySetting.current.unavailable_weekdays.to_json.html_safe %>
  const hasErrors = <%= @order&.errors&.any? ? "true" : "false" %>
  const minDate = new Date()
  minDate.setDate(minDate.getDate() + 1)

  const picker = flatpickr(input, {
    locale: "es",
    minDate: minDate,
    dateFormat: "Y-m-d",
    allowInput: false,
    clickOpens: true,

    disable: [
      function(date) {
        return disabledDays.includes(date.getDay())
      }
    ],

    onReady: function(selectedDates, dateStr, instance) {
      input.placeholder = "Seleccioná una fecha"

      if (hasErrors) {
        instance.clear()
      }
    }
  })

  input.addEventListener("focus", function() {
    picker.open()
  })

  input.addEventListener("click", function() {
    picker.open()
  })
}

initDeliveryDatePicker()
document.addEventListener("turbo:load", initDeliveryDatePicker)
document.addEventListener("DOMContentLoaded", initDeliveryDatePicker)
</script>