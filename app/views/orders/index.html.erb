<div class="container py-5">
  <div class="d-flex justify-content-between align-items-start mb-5 mobile-stack">
    <div>
      <h1 class="fw-bold mb-1">Mis pedidos</h1>
      <div class="text-muted">Historial de pedidos realizados</div>
    </div>

    <%= link_to "Nuevo pedido", dashboard_path, class: "btn btn-hans mt-3 mt-md-0" %>
  </div>

  <div class="product-card mb-4">
    <h2 class="fs-5 fw-bold mb-3">Estado de cuenta</h2>

    <div class="row">
      <div class="col-4">
        <div class="text-muted small mb-1">Total facturado</div>
        <div class="fw-bold">$<%= number_with_delimiter(@total_invoiced_cents / 100) %></div>
      </div>

      <div class="col-4">
        <div class="text-muted small mb-1">Total pagado</div>
        <div class="fw-bold">$<%= number_with_delimiter(@total_paid_cents / 100) %></div>
      </div>

      <div class="col-4">
        <div class="text-muted small mb-1">Saldo pendiente</div>
        <div class="fw-bold">$<%= number_with_delimiter(@balance_due_cents / 100) %></div>
      </div>
    </div>
  </div>

  <% if @orders.empty? %>
    <div class="product-card">
      Todavía no hiciste pedidos.
    </div>
  <% else %>
    <% @orders.each do |order| %>
      <div class="product-card mb-3">
        <div class="d-flex justify-content-between align-items-start">
          <div>
            <div class="fw-bold fs-5"><%= order.number %></div>
            <div class="text-muted">
              Entrega: <%= order.delivery_date.strftime("%d/%m/%Y") %>
            </div>
            <div class="small mt-2">
              <%= order.order_items.sum(&:quantity) %> unidades
            </div>
          </div>

          <div class="text-end">
            <div class="fw-bold">
              $<%= number_with_delimiter(order.total_cents / 100) %>
            </div>

            <div class="text-muted small">
              Pagado: $<%= number_with_delimiter(order.amount_paid_cents / 100) %>
            </div>

            <div class="text-muted small mb-2">
              Saldo: $<%= number_with_delimiter(order.balance_due_cents / 100) %>
            </div>

            <div class="badge bg-secondary">
              <%= order.status_label %>
            </div>

            <div class="badge bg-light text-dark border mb-3">
              <%= order.payment_status_label %>
            </div>

            <div class="d-flex gap-2">
              <%= link_to "Ver", order_path(order), class: "btn btn-sm btn-outline-dark" %>

              <%= button_to "Repetir",
                repeat_order_path(order),
                method: :post,
                class: "btn btn-sm btn-dark" %>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  <% end %>
</div>