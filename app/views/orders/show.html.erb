<div class="container py-5">
  <div class="product-card mb-4">
    <div class="d-flex justify-content-between align-items-start mb-4">
      <div>
        <h1 class="fw-bold mb-2">
          Pedido confirmado
        </h1>

        <div class="text-muted">
          Número <%= @order.number %>
        </div>
      </div>

      <% payment_badge_class = case @order.payment_status
         when "paid" then "bg-success"
         when "partial" then "bg-warning text-dark"
         else "bg-secondary"
         end %>

      <div class="badge <%= payment_badge_class %> fs-6">
        <%= @order.payment_status_label %>
      </div>
    </div>

    <div class="row">
      <div class="col-6 col-md-3">
        <div class="text-muted small mb-1">
          Estado
        </div>

        <div class="fw-bold">
          <%= @order.status_label %>
        </div>
      </div>

      <div class="col-6 col-md-3">
        <div class="text-muted small mb-1">
          Forma de pago
        </div>

        <div class="fw-bold">
          <%= @order.payment_method_selected_label || "Sin definir" %>
        </div>
      </div>

      <div class="col-6 col-md-3">
        <div class="text-muted small mb-1">
          Pagado
        </div>

        <div class="fw-bold">
          <%= format_money(@order.amount_paid_cents) %>
        </div>
      </div>

      <div class="col-6 col-md-3">
        <div class="text-muted small mb-1">
          Saldo pendiente
        </div>

        <div class="fw-bold">
          <%= format_money(@order.balance_due_cents) %>
        </div>
      </div>
    </div>
  </div>

  <%= render "orders/receipt", order: @order %>
</div>
