<div class="container py-5">
  <div class="d-flex justify-content-between align-items-center mb-5">
    <div>
      <h1 class="fw-bold mb-1">Producción</h1>
      <div class="text-muted">
        Hoy + próximos 6 días
      </div>
    </div>

    <%= link_to "← Admin", admin_root_path, class: "btn btn-outline-dark" %>
  </div>

  <div class="product-card">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h3 class="fw-bold mb-0">Próximos días</h3>

      <div class="text-muted small">
        Tocá un día para abrir producción
      </div>
    </div>

    <div class="production-calendar">
      <% @week_days.each do |day| %>
        <%= link_to admin_production_path(day[:date]),
          class: "production-calendar-day" do %>

          <div class="production-calendar-weekday">
            <%= l(day[:date], format: "%A") %>
          </div>

          <div class="production-calendar-date">
            <%= l(day[:date], format: "%d/%m") %>
          </div>

          <div class="production-calendar-orders">
            <%= day[:orders_count] %> pedidos
          </div>

        <% end %>
      <% end %>
    </div>
  </div>

  <% if @past_days.present? %>
    <div class="product-card mt-4">
      <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold mb-0">Días pasados</h3>

        <div class="text-muted small">
          Últimos 30 días con pedidos
        </div>
      </div>

      <div class="production-calendar production-calendar-past">
        <% @past_days.each do |day| %>
          <%= link_to admin_production_path(day[:date]),
            class: "production-calendar-day production-calendar-day-small" do %>

            <div class="production-calendar-weekday">
              <%= l(day[:date], format: "%A") %>
            </div>

            <div class="production-calendar-date">
              <%= l(day[:date], format: "%d/%m") %>
            </div>

            <div class="production-calendar-orders">
              <%= day[:orders_count] %> pedidos
            </div>

          <% end %>
        <% end %>
      </div>
    </div>
  <% end %>
</div>