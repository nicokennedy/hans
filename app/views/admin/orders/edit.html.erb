<div class="container py-5">
  <div class="d-flex gap-2 mb-4">
    <%= link_to "← Volver al pedido", admin_order_path(@order), class: "btn btn-outline-dark" %>
  </div>

  <div class="product-card">
    <h1 class="fw-bold mb-2">Editar pedido <%= @order.number %></h1>
    <div class="text-muted mb-4"><%= @order.customer.name %></div>

    <%= form_with model: [:admin, @order], local: true do |f| %>
      <div class="mb-3">
        <%= f.label :delivery_date, "Fecha de entrega", class: "form-label" %>
        <%= f.date_field :delivery_date, class: "form-control" %>
      </div>

      <div class="mb-3">
        <%= f.label :status, "Estado", class: "form-label" %>
        <%= f.select :status,
          Order.statuses.keys.map { |status| [status.humanize, status] },
          {},
          class: "form-select" %>
      </div>

      <div class="mb-4">
        <%= f.label :customer_comment, "Comentario", class: "form-label" %>
        <%= f.text_area :customer_comment, rows: 3, class: "form-control" %>
      </div>

      <h4 class="mb-3">Productos del pedido</h4>

      <% @order.order_items.each do |item| %>
  <div class="d-flex justify-content-between align-items-center border-bottom py-3">
    <div>
      <div class="fw-bold"><%= item.product_name_snapshot %></div>
      <div class="text-muted">
        $<%= number_with_delimiter(item.unit_price_cents_snapshot / 100) %> c/u
      </div>
    </div>

<div style="width: 180px;">
  <label class="form-label small">Cantidad</label>

  <%= number_field_tag "order_items[#{item.id}][quantity]",
      item.quantity,
      min: 1,
      class: "form-control mb-2" %>

  <div class="form-check">
    <%= check_box_tag "order_items[#{item.id}][remove]",
        "1",
        false,
        class: "form-check-input" %>

    <label class="form-check-label">
      Eliminar
    </label>
  </div>
</div>

    <div class="fw-bold">
      $<%= number_with_delimiter(item.line_revenue_cents / 100) %>
    </div>
  </div>
<% end %>

      <div class="mt-4">
        <%= f.submit "Guardar cambios", class: "btn btn-dark" %>
      </div>
    <% end %>
  </div>
</div>