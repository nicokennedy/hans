<div class="container py-5">
  <div class="d-flex gap-2 mb-4">
    <%= link_to "← Volver", admin_orders_path, class: "btn btn-outline-dark" %>

   <%= link_to "Editar pedido",
       edit_admin_order_path(@order),
       class: "btn btn-dark" %>

    <% whatsapp_url = whatsapp_order_link_url(@order) %>
    <% if whatsapp_url %>
      <%= link_to "Enviar pedido por WhatsApp",
          whatsapp_url,
          target: "_blank",
          class: "btn btn-success" %>
    <% else %>
      <span class="text-muted small align-self-center" title="Configurá WHATSAPP_OBRADOR_NUMBER para habilitar este botón">
        Enviar por WhatsApp no disponible
      </span>
    <% end %>
  </div>

  <div class="product-card">
    <h1 class="fw-bold mb-2"><%= @order.number %></h1>
    <div class="text-muted mb-4"><%= @order.customer.name %></div>

    <div class="row mb-4">
      <div class="col-md-4">
        <div class="text-muted small">Entrega</div>
        <div class="fw-bold"><%= @order.delivery_date.strftime("%d/%m/%Y") %></div>
      </div>

      <div class="col-md-4">
        <div class="text-muted small">Estado</div>
        <div class="fw-bold"><%= @order.status_label %></div>
      </div>

      <div class="col-md-4">
        <div class="text-muted small">Total</div>
        <div class="fw-bold">$<%= number_with_delimiter(@order.total_cents / 100) %></div>
      </div>
    </div>

    <div class="row mb-5">
      <div class="col-md-4">
        <div class="text-muted small">Pagado</div>
        <div class="fw-bold">$<%= number_with_delimiter(@order.amount_paid_cents / 100) %></div>
      </div>

      <div class="col-md-4">
        <div class="text-muted small">Saldo pendiente</div>
        <div class="fw-bold">$<%= number_with_delimiter(@order.balance_due_cents / 100) %></div>
      </div>

      <div class="col-md-4">
        <div class="text-muted small">Estado de pago</div>
        <div class="fw-bold"><%= @order.payment_status_label %></div>
      </div>
    </div>

    <h4 class="mb-3">Pagos registrados</h4>

    <% if @order.payments.empty? %>
      <div class="text-muted mb-4">Todavía no se registraron pagos para este pedido.</div>
    <% else %>
      <% @order.payments.sort_by(&:paid_at).reverse_each do |payment| %>
        <div class="d-flex justify-content-between align-items-center border-bottom py-3">
          <div>
            <div class="fw-bold">$<%= number_with_delimiter(payment.amount_cents / 100) %></div>
            <div class="text-muted small">
              <%= payment.paid_at.strftime("%d/%m/%Y") %> · <%= payment.payment_method_label %>
            </div>
            <% if payment.note.present? %>
              <div class="text-muted small"><%= payment.note %></div>
            <% end %>
          </div>

          <%= button_to "Eliminar",
              admin_order_payment_path(@order, payment),
              method: :delete,
              class: "btn btn-sm btn-outline-danger",
              form: { class: "d-inline" },
              data: { turbo_confirm: "¿Eliminar este pago? Se recalculará el saldo del pedido." } %>
        </div>
      <% end %>
    <% end %>

    <div class="mt-4 p-3 border rounded">
      <h5 class="mb-3">Registrar pago</h5>

      <%= form_with model: [:admin, @order, Payment.new], local: true do |f| %>
        <div class="row g-3 align-items-end">
          <div class="col-md-3">
            <%= f.label :amount, "Monto", class: "form-label" %>
            <%= f.number_field :amount, min: 0, class: "form-control", required: true %>
          </div>

          <div class="col-md-3">
            <%= f.label :paid_at, "Fecha", class: "form-label" %>
            <%= f.date_field :paid_at, value: Date.current, class: "form-control", required: true %>
          </div>

          <div class="col-md-3">
            <%= f.label :payment_method, "Forma de pago", class: "form-label" %>
            <%= f.select :payment_method,
                Payment::PAYMENT_METHOD_LABELS.map { |value, label| [label, value] },
                { prompt: "Seleccionar" },
                class: "form-select", required: true %>
          </div>

          <div class="col-md-3">
            <%= f.label :note, "Nota (opcional)", class: "form-label" %>
            <%= f.text_field :note, class: "form-control" %>
          </div>
        </div>

        <div class="mt-3">
          <%= f.submit "Registrar pago", class: "btn btn-dark" %>
        </div>
      <% end %>
    </div>

    <h4 class="mb-3 mt-5">Productos</h4>

    <% @order.order_items.each do |item| %>
      <div class="d-flex justify-content-between border-bottom py-3">
        <div>
          <div class="fw-bold"><%= item.product_name_snapshot %></div>
          <div class="text-muted">x<%= item.quantity %></div>
        </div>

        <div class="fw-bold">
          $<%= number_with_delimiter(item.line_revenue_cents / 100) %>
        </div>
      </div>
    <% end %>

    <% if @order.customer_comment.present? %>
      <div class="mt-4">
        <div class="text-muted small">Comentario cliente</div>
        <div><%= @order.customer_comment %></div>
      </div>
    <% end %>
  </div>
</div>