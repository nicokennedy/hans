<div class="container py-5">
  <h1 class="fw-bold mb-4">Pedidos recibidos</h1>

  <% @orders.each do |order| %>
    <%= link_to admin_order_path(order), class: "text-decoration-none text-dark" do %>
      <div class="product-card mb-3">
        <div class="d-flex justify-content-between">
          <div>
            <div class="fw-bold"><%= order.number %></div>
            <div class="text-muted"><%= order.customer.name %></div>
            <div class="small">Entrega: <%= order.delivery_date.strftime("%d/%m/%Y") %></div>
          </div>

          <div class="text-end">
            <div class="fw-bold">$<%= number_with_delimiter(order.total_cents / 100) %></div>
            <div class="badge bg-secondary"><%= order.status.humanize %></div>
          </div>
        </div>
      </div>
    <% end %>
  <% end %>
</div>