<%= form_with model: [:admin, @product], local: true do |f| %>
  <% if @product.errors.any? %>
    <div class="alert alert-danger">
      <%= @product.errors.full_messages.join(", ") %>
    </div>
  <% end %>

  <div class="product-card">
    <div class="mb-3">
      <%= f.label :name, "Nombre", class: "form-label" %>
      <%= f.text_field :name, class: "form-control", required: true %>
    </div>

    <div class="mb-3">
      <%= f.label :category_id, "Categoría", class: "form-label" %>
      <%= f.collection_select :category_id,
        Category.ordered,
        :id,
        :name,
        { prompt: "Seleccionar categoría" },
        { class: "form-select", required: true } %>
    </div>

    <div class="mb-3">
			<%= f.label :price_amount, "Precio", class: "form-label" %>
			<%= f.number_field :price_amount,
				class: "form-control",
				min: 0,
				required: true %>

		</div>

		<div class="mb-3">
			<%= f.label :cost_amount, "Costo interno", class: "form-label" %>

			<%= f.number_field :cost_amount,
				class: "form-control",
				min: 0 %>

		</div>

    <div class="mb-3">
      <%= f.label :position, "Orden", class: "form-label" %>
      <%= f.number_field :position, class: "form-control", min: 0 %>
    </div>

    <div class="form-check mb-4">
      <%= f.check_box :active, class: "form-check-input" %>
      <%= f.label :active, "Activo", class: "form-check-label" %>
    </div>

    <div class="d-flex gap-2">
      <%= f.submit "Guardar", class: "btn btn-dark" %>
      <%= link_to "Cancelar", admin_products_path, class: "btn btn-outline-dark" %>
    </div>
  </div>
<% end %>