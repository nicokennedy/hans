<div class="container py-5">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h1>Productos</h1>
      <p class="text-muted mb-0">Alta, edición y costos internos.</p>
    </div>

    <div class="d-flex gap-2">
      <%= link_to "← Admin", admin_root_path, class: "btn btn-outline-dark" %>
      <%= link_to "Importar archivo", import_admin_products_path, class: "btn btn-outline-dark" %>
      <%= link_to "+ Nuevo producto", new_admin_product_path, class: "btn btn-dark" %>
    </div>
  </div>

  <div class="product-card mb-4">
    <%= form_with url: admin_products_path, method: :get, local: true do |f| %>
      <div class="row g-3 align-items-end">
        <div class="col-12 col-lg-3">
          <%= f.label :q, "Buscar por nombre", class: "form-label" %>
          <%= f.search_field :q, value: params[:q], class: "form-control", placeholder: "Nombre del producto" %>
        </div>
        <div class="col-12 col-sm-6 col-lg-3">
          <%= f.label :category_id, "Categoría", class: "form-label" %>
          <%= f.collection_select :category_id, @categories, :id, :name, { include_blank: "Todas las categorías", selected: params[:category_id] }, class: "form-select" %>
        </div>
        <div class="col-12 col-sm-6 col-lg-2">
          <%= f.label :status, "Estado", class: "form-label" %>
          <%= f.select :status, [["Todos", ""], ["Activos", "active"], ["Inactivos", "inactive"]], { selected: params[:status] }, class: "form-select" %>
        </div>
        <div class="col-12 col-sm-6 col-lg-2">
          <%= f.label :sort, "Ordenar por", class: "form-label" %>
          <%= f.select :sort, [["Orden predeterminado", ""], ["Nombre", "name"], ["Categoría", "category"], ["Precio", "price"], ["Costo", "cost"]], { selected: params[:sort] }, class: "form-select" %>
        </div>
        <div class="col-12 col-sm-6 col-lg-2">
          <%= f.label :direction, "Dirección", class: "form-label" %>
          <%= f.select :direction, [["Ascendente", "asc"], ["Descendente", "desc"]], { selected: params[:direction] }, class: "form-select" %>
        </div>
        <div class="col-12 d-flex flex-wrap gap-2">
          <%= f.submit "Aplicar", class: "btn btn-dark" %>
          <%= link_to "Limpiar filtros", admin_products_path, class: "btn btn-outline-dark" %>
        </div>
      </div>
    <% end %>
  </div>
  <div class="product-card">
    <% if @products.empty? %>
      <div class="p-4 text-center">
        <h2 class="h5">No se encontraron productos</h2>
        <p class="text-muted">Probá cambiar la búsqueda o los filtros seleccionados.</p>
        <%= link_to "Limpiar filtros", admin_products_path, class: "btn btn-outline-dark" %>
      </div>
    <% else %>
    <div class="table-responsive">
      <table class="table align-middle mb-0">
      <thead>
        <tr>
          <th>Nombre</th>
          <th>Categoría cliente</th>
        	<th>Categoría interna</th>
          <th>Precio</th>
          <th>Costo</th>
          <th>Activo</th>
          <th></th>
        </tr>
      </thead>

      <tbody>
        <% @products.each do |product| %>
          <tr>
            <td class="fw-bold"><%= product.name %></td>
            <td><%= product.category&.name %></td>
						<td><%= product.internal_category.presence || "-" %></td>
            <td>$<%= number_with_delimiter(product.price_cents.to_i / 100) %></td>
            <td>$<%= number_with_delimiter(product.cost_cents.to_i / 100) %></td>
            <td>
              <% if product.active? %>
                <span class="badge bg-success">Sí</span>
              <% else %>
                <span class="badge bg-secondary">No</span>
              <% end %>
            </td>
            <td class="text-end">
              <%= link_to "Editar", edit_admin_product_path(product, params.permit(:q, :category_id, :status, :sort, :direction)), class: "btn btn-sm btn-outline-dark" %>

              <%= button_to "Eliminar",
                admin_product_path(product, params.permit(:q, :category_id, :status, :sort, :direction)),
                method: :delete,
                class: "btn btn-sm btn-outline-danger",
                form: { class: "d-inline" },
                data: { turbo_confirm: "¿Seguro que querés eliminar este producto?" } %>
            </td>
          </tr>
        <% end %>
      </tbody>
      </table>
    </div>
    <% end %>
  </div>
</div>
