<div class="container py-5">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h1 class="fw-bold mb-1"><%= @customer.name %></h1>
      <p class="text-muted mb-0"><%= @customer.contact_name.presence || @customer.email.presence %></p>
    </div>

    <div class="d-flex gap-2">
      <%= link_to "← Clientes", admin_customers_path, class: "btn btn-outline-dark" %>
      <%= link_to "Editar cliente", edit_admin_customer_path(@customer), class: "btn btn-dark" %>
    </div>
  </div>

  <%= render "period_filter" %>

  <div class="product-card mb-4">
    <h2 class="fs-5 fw-bold mb-3">Resumen del período (<%= @collections_period.label %>)</h2>

    <div class="row">
      <div class="col-6 col-md-3">
        <div class="text-muted small mb-1">Total facturado</div>
        <div class="fw-bold fs-5">$<%= number_with_delimiter(@invoiced_cents / 100) %></div>
      </div>

      <div class="col-6 col-md-3">
        <div class="text-muted small mb-1">Total cobrado</div>
        <div class="fw-bold fs-5">$<%= number_with_delimiter(@paid_cents / 100) %></div>
      </div>

      <div class="col-6 col-md-3">
        <div class="text-muted small mb-1">Saldo pendiente</div>
        <div class="fw-bold fs-5">$<%= number_with_delimiter((@invoiced_cents - @paid_cents) / 100) %></div>
      </div>

      <div class="col-6 col-md-3">
        <div class="text-muted small mb-1">% Cobrado</div>
        <div class="fw-bold fs-5">
          <% percent = collections_percent(@invoiced_cents, @paid_cents) %>
          <%= percent.nil? ? "—" : "#{percent}%" %>
        </div>
      </div>
    </div>
  </div>

  <div class="product-card">
    <h4 class="mb-3">Pedidos del período</h4>

    <% if @orders.empty? %>
      <div class="text-muted">No hay pedidos de este cliente en el período seleccionado.</div>
    <% else %>
      <div class="table-responsive">
        <table class="table align-middle mb-0">
          <thead>
            <tr>
              <th>Número</th>
              <th>Entrega</th>
              <th>Total</th>
              <th>Pagado</th>
              <th>Saldo pendiente</th>
              <th>Estado de pago</th>
              <th class="text-end">Acciones</th>
            </tr>
          </thead>

          <tbody>
            <% @orders.each do |order| %>
              <% payment_badge_class = case order.payment_status
                 when "paid" then "bg-success"
                 when "partial" then "bg-warning text-dark"
                 else "bg-secondary"
                 end %>
              <tr>
                <td class="fw-bold"><%= order.number %></td>
                <td><%= order.delivery_date.strftime("%d/%m/%Y") %></td>
                <td>$<%= number_with_delimiter(order.total_cents / 100) %></td>
                <td>$<%= number_with_delimiter(order.amount_paid_cents / 100) %></td>
                <td>$<%= number_with_delimiter(order.balance_due_cents / 100) %></td>
                <td><span class="badge <%= payment_badge_class %>"><%= order.payment_status_label %></span></td>
                <td class="text-end">
                  <%= link_to "Ver pedido", admin_order_path(order), class: "btn btn-sm btn-outline-dark" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% end %>
  </div>
</div>
