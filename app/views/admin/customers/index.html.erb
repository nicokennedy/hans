<div class="container py-5">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h1>Clientes</h1>
      <p class="text-muted mb-0">Datos comerciales y accesos al portal.</p>
    </div>

    <div class="d-flex gap-2">
      <%= link_to "← Admin", admin_root_path, class: "btn btn-outline-dark" %>
      <%= link_to "Nuevo cliente", new_admin_customer_path, class: "btn btn-dark" %>
    </div>
  </div>

  <%= render "period_filter" %>

  <div class="product-card mb-4">
    <h2 class="fs-5 fw-bold mb-3">Resumen del período (<%= @collections_period.label %>)</h2>

    <div class="row">
      <div class="col-6 col-md-3">
        <div class="text-muted small mb-1">Facturado</div>
        <div class="fw-bold fs-5">$<%= number_with_delimiter(@total_invoiced_cents / 100) %></div>
      </div>

      <div class="col-6 col-md-3">
        <div class="text-muted small mb-1">Cobrado</div>
        <div class="fw-bold fs-5">$<%= number_with_delimiter(@total_paid_cents / 100) %></div>
      </div>

      <div class="col-6 col-md-3">
        <div class="text-muted small mb-1">Pendiente</div>
        <div class="fw-bold fs-5">$<%= number_with_delimiter((@total_invoiced_cents - @total_paid_cents) / 100) %></div>
      </div>

      <div class="col-6 col-md-3">
        <div class="text-muted small mb-1">% Cobrado</div>
        <div class="fw-bold fs-5">
          <% percent = collections_percent(@total_invoiced_cents, @total_paid_cents) %>
          <%= percent.nil? ? "—" : "#{percent}%" %>
        </div>
      </div>
    </div>
  </div>

  <div class="product-card">
    <div class="table-responsive">
      <table class="table align-middle mb-0">
        <thead>
          <tr>
            <th>Negocio</th>
            <th>Contacto</th>
            <th>Email comercial</th>
            <th>Teléfono</th>
            <th>Email de acceso</th>
            <th>Estado</th>
            <th>Facturado</th>
            <th>Cobrado</th>
            <th>Saldo</th>
            <th>% Cobrado</th>
            <th>Estado de cuenta</th>
            <th class="text-end">Acciones</th>
          </tr>
        </thead>

        <tbody>
          <% @customers.each do |customer| %>
            <% access_user = customer.users.first %>
            <% invoiced = @invoiced_by_customer[customer.id].to_i %>
            <% paid = @paid_by_customer[customer.id].to_i %>
            <tr>
              <td class="fw-bold"><%= link_to customer.name, admin_customer_path(customer), class: "text-decoration-none text-dark" %></td>
              <td><%= customer.contact_name.presence || "-" %></td>
              <td><%= customer.email.presence || "-" %></td>
              <td><%= customer.phone.presence || "-" %></td>
              <td><%= access_user&.email.presence || "Sin usuario" %></td>
              <td>
                <% if customer.active? %>
                  <span class="badge bg-success">Activo</span>
                <% else %>
                  <span class="badge bg-secondary">Inactivo</span>
                <% end %>
              </td>
              <td>$<%= number_with_delimiter(invoiced / 100) %></td>
              <td>$<%= number_with_delimiter(paid / 100) %></td>
              <td>$<%= number_with_delimiter((invoiced - paid) / 100) %></td>
              <td>
                <% customer_percent = collections_percent(invoiced, paid) %>
                <%= customer_percent.nil? ? "—" : "#{customer_percent}%" %>
              </td>
              <td>
                <% account_status = collections_status_label(invoiced, paid) %>
                <% if account_status == "Al día" %>
                  <span class="badge bg-success">Al día</span>
                <% elsif account_status == "Saldo pendiente" %>
                  <span class="badge bg-warning text-dark">Saldo pendiente</span>
                <% else %>
                  <span class="text-muted">—</span>
                <% end %>
              </td>
              <td>
                <div class="d-flex justify-content-end gap-2">
                  <%= link_to "Ver", admin_customer_path(customer), class: "btn btn-sm btn-outline-dark" %>
                  <%= link_to "Editar", edit_admin_customer_path(customer), class: "btn btn-sm btn-outline-dark" %>
                  <%= button_to(
                    customer.active? ? "Desactivar" : "Reactivar",
                    toggle_active_admin_customer_path(customer),
                    method: :patch,
                    class: "btn btn-sm #{customer.active? ? 'btn-outline-danger' : 'btn-outline-success'}",
                    form: { data: { turbo_confirm: customer.active? ? "¿Desactivar el acceso de este cliente?" : nil } }
                  ) %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
