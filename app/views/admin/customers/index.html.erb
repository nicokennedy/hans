<div class="container py-5">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h1>Clientes</h1>
      <p class="text-muted mb-0">Datos comerciales y accesos al portal.</p>
    </div>

    <div class="d-flex gap-2">
      <%= link_to "← Admin", admin_root_path, class: "btn btn-outline-dark" %>
      <%= link_to "Nuevo cliente", new_admin_customer_path, class: "btn btn-dark" %>
    </div>
  </div>

  <div class="product-card">
    <div class="table-responsive">
      <table class="table align-middle mb-0">
        <thead>
          <tr>
            <th>Negocio</th>
            <th>Contacto</th>
            <th>Email comercial</th>
            <th>Teléfono</th>
            <th>Email de acceso</th>
            <th>Estado</th>
            <th class="text-end">Acciones</th>
          </tr>
        </thead>

        <tbody>
          <% @customers.each do |customer| %>
            <% access_user = customer.users.first %>
            <tr>
              <td class="fw-bold"><%= customer.name %></td>
              <td><%= customer.contact_name.presence || "-" %></td>
              <td><%= customer.email.presence || "-" %></td>
              <td><%= customer.phone.presence || "-" %></td>
              <td><%= access_user&.email.presence || "Sin usuario" %></td>
              <td>
                <% if customer.active? %>
                  <span class="badge bg-success">Activo</span>
                <% else %>
                  <span class="badge bg-secondary">Inactivo</span>
                <% end %>
              </td>
              <td>
                <div class="d-flex justify-content-end gap-2">
                  <%= link_to "Editar", edit_admin_customer_path(customer), class: "btn btn-sm btn-outline-dark" %>
                  <%= button_to(
                    customer.active? ? "Desactivar" : "Reactivar",
                    toggle_active_admin_customer_path(customer),
                    method: :patch,
                    class: "btn btn-sm #{customer.active? ? 'btn-outline-danger' : 'btn-outline-success'}",
                    form: { data: { turbo_confirm: customer.active? ? "¿Desactivar el acceso de este cliente?" : nil } }
                  ) %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
