<div class="product-card mb-4">
  <%= form_with url: request.path, method: :get, local: true do %>
    <div class="row g-3 align-items-end">
      <div class="col-12 col-md-3">
        <label class="form-label">Período</label>
        <%= select_tag :period,
            options_for_select(Collections::PeriodFilter::VALID_PERIODS.map { |p| [Collections::PeriodFilter::LABELS[p], p] }, @collections_period.period),
            class: "form-select" %>
      </div>

      <div class="col-12 col-md-3">
        <label class="form-label">Desde</label>
        <%= date_field_tag :from, @collections_period.from, class: "form-control" %>
      </div>

      <div class="col-12 col-md-3">
        <label class="form-label">Hasta</label>
        <%= date_field_tag :to, @collections_period.to, class: "form-control" %>
      </div>

      <div class="col-12 col-md-3">
        <%= submit_tag "Aplicar", class: "btn btn-dark w-100" %>
      </div>
    </div>
    <div class="form-text mt-2">"Desde"/"Hasta" solo se usan cuando el período es Personalizado.</div>
  <% end %>
</div>
