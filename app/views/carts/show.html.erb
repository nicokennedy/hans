<div class="container cart-page py-4">
  <% total_cents = @cart_items.sum { |item| item[:subtotal_cents] } %>
  <% total_quantity = @cart_items.sum { |item| item[:quantity] } %>

  <div class="cart-header mb-4">
    <div>
      <h1 class="fw-bold mb-1">Carrito</h1>
      <div class="text-muted">Revisá tu pedido antes de confirmar</div>
      <div class="fw-bold mt-2"><%= total_quantity %> productos en el carrito</div>
    </div>

    <%= link_to "Agregar más productos", dashboard_path, class: "btn btn-outline-dark btn-sm" %>
  </div>

  <% if @cart_items.empty? %>
    <div class="product-card">
      <h4 class="mb-3">Tu carrito está vacío</h4>
      <%= link_to "Ver productos", dashboard_path, class: "btn btn-hans" %>
    </div>
  <% else %>
    <div class="cart-total-card mb-3">
      <div>
        <div class="text-muted small">Total</div>
        <div class="fw-bold fs-4">$<%= number_with_delimiter(total_cents / 100) %></div>
      </div>

      <div class="d-flex gap-2 align-items-center">
        <%= button_to "Vaciar carrito",
          clear_cart_path,
          method: :delete,
          class: "btn btn-sm btn-outline-dark" %>

        <%= link_to "Continuar",
          new_order_path,
          class: "btn btn-hans" %>
      </div>
    </div>

    <div class="cart-items">
      <% @cart_items.each do |item| %>
        <div class="cart-item-card">
          <div class="cart-item-main">
            <div class="cart-item-name"><%= item[:product].name %></div>
            <div class="cart-item-category"><%= item[:product].category.name %></div>
            <div class="cart-item-unit-price">
              $<%= number_with_delimiter(item[:product].price_cents / 100) %>
            </div>
          </div>

          <div class="cart-item-side">
            <div class="mb-2">
              <%= render "carts/quantity_control", product: item[:product] %>
            </div>

            <div class="cart-item-subtotal">
              $<%= number_with_delimiter(item[:subtotal_cents] / 100) %>
            </div>

            <%= button_to "Eliminar",
              remove_item_cart_path(product_id: item[:product].id),
              method: :delete,
              class: "btn btn-sm btn-outline-dark mt-2" %>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
</div>