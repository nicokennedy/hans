<div class="container py-4">
  <% cart_count = session[:cart].to_h.values.map(&:to_i).sum %>

  <div class="mb-4">
    <div class="d-flex justify-content-between align-items-start gap-3">
      <div>
        <h1 class="fw-bold mb-1">HANS</h1>
        <div class="text-muted">Hola <%= current_user.customer.name %></div>
      </div>

      <%= turbo_frame_tag "cart_count_big" do %>
        <% cart_count = session[:cart].to_h.values.map(&:to_i).sum %>

        <%= link_to "Carrito (#{cart_count})",
          cart_path,
          class: "btn btn-hans btn-lg",
          data: { turbo_frame: "_top" } %>
      <% end %>
    </div>

    <div class="mt-3">
      <%= link_to "Mis pedidos", orders_path, class: "btn btn-sm btn-outline-dark" %>
    </div>
  </div>

  <div class="mb-4">
    <h2 class="fw-bold fs-4 mb-1">Hacé tu pedido</h2>
    <div class="text-muted small">Sumá productos y confirmá desde el carrito.</div>
  </div>

  <% Category.active.ordered.includes(:products).each do |category| %>
    <% products = category.products.active.order(:position, :name) %>
    <% next if products.empty? %>

    <section class="mb-4">
      <h3 class="category-title"><%= category.name %></h3>

      <div class="order-list">
        <% products.each do |product| %>
          <% quantity = session[:cart].to_h[product.id.to_s].to_i %>

          <div class="order-item-card" id="product-<%= product.id %>">
            <div class="order-item-info">
              <div class="order-item-name"><%= product.name %></div>

              <% if product.description.present? %>
                <div class="order-item-description"><%= product.description %></div>
              <% end %>

              <div class="order-item-price">
                $<%= number_with_delimiter(product.price_cents / 100) %>
              </div>
            </div>

            <%= render "carts/quantity_control", product: product %>
          </div>
        <% end %>
      </div>
    </section>
  <% end %>

</div>